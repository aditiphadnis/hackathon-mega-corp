FROM python:3.11-slim

WORKDIR /workspace

# System deps first (includes Node.js for npx MCP servers)
RUN apt-get update && apt-get install -y nodejs npm && rm -rf /var/lib/apt/lists/*

# Python deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy agent code
COPY ceo_assistant/ ./ceo_assistant/

EXPOSE 8000

CMD ["adk", "api_server", "--host", "0.0.0.0", "--port", "8000", "/workspace"]